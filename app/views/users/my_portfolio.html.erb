<h1>My Portfolio</h1>

<div class="search-area pb-2">
    <h4>Search stocks</h4>
    <%# adding 'remote: true' turns this field into a AJAX request  %>
    <%= form_tag search_stock_path, method: :post do %>
        <div class="form-group row">
            <div class="col-sm-9 no-right-padding">
                <%= text_field_tag :stock, params[:stock], placeholder: "Enter stock ticker symbol", autofocus: true, class:"form-control form-control-lg" %>
            </div>
            <div class="col-sm-3">
                <%= button_tag type: :submit, class: "btn btn-success" do %>
                    <%= fa_icon "search 2x" %>
                <% end %>
            </div>
        </div>
    <% end %>
</div>
<div id="flash-messages"></div>
<div id="search-results"> </div>

<%= render "stocks/tracked_stocks" %>