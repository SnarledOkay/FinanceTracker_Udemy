<h1>My Friends</h1>

<div class="search-area pb-2">
    <h3>Search friends</h3>
    <%= form_tag search_friend_path, method: :post do %>
        <div class="form-group row">
            <div class="col-sm-9 no-right-padding">
                <%= text_field_tag :friend_info, params[:friend_info], placeholder: "Enter name or email", autofocus: true, class:"form-control form-control-lg" %>
            </div>
            <div class="col-sm-3">
                <%= button_tag type: :submit, class: "btn btn-success" do %>
                    <%= fa_icon "search 2x" %>
                <% end %>
            </div>
        </div>
    <% end %>
</div>

<div id="flash-messages"></div>
<div id="found-users"></div>

<% if !@friends.empty? %>
    <%= render "friends/friend_list" %>
<% end %>