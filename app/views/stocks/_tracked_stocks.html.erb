<% if !@tracked_stocks.empty? %>
	<div class="row">
		<div class="col-9">
			<h3 class="border-bottom border-secondary">Current tracked stocks</h3>
			<table class="table">
				<thead>
					<tr>
						<th scope="col">Ticker</th>
						<th scope="col">Company Name</th>
						<th scope="col">Price</th>
						<th scope="col">Action</th>
					</tr>
				</thead>
				<% @tracked_stocks.each do |stock| %>
					<tbody>
						<tr>
							<th scope="row"><%= stock.ticker %></th>
							<td><%= stock.company_name %></td>
							<td><%= stock.last_price %></td>
							<% if current_user.id == @user.id %>
								<td><%= link_to "Stop tracking", user_stock_path(stock), data: {turbo_method: :delete, turbo_confirm: "Do you want to stop tracking this stock?"}, class:"btn btn-sm btn-warning" %></td>
							<% else %>
								<td>
									<% if current_user.can_track_stock?(stock.ticker) %>
										<%= link_to "Add to portfolio", user_stocks_path(stock), data: {turbo_method: :post}, class: "btn btn-sm btn-primary" %>
									<% else %>
										<div class="text-secondary fst-italic">
											<% if current_user.stock_already_tracked?(stock.ticker) %>
												You are already tracking this stock
											<% elsif !current_user.under_stock_limit? %>	
												You are already tracking 10 stocks
											<% end %>
										</div>
									<% end %>
								</td>
							<% end %>
						</tr>
					</tbody>
				<% end %>
			</table>
		</div>
	</div>
<% end %>